{
  "$defs": {
    "AssertionCreatedPayload": {
      "additionalProperties": false,
      "properties": {
        "assertion_id": {
          "format": "uuid",
          "title": "Assertion Id",
          "type": "string"
        },
        "assertion_type": {
          "enum": [
            "background",
            "method",
            "result",
            "limitation"
          ],
          "title": "Assertion Type",
          "type": "string"
        },
        "state": {
          "enum": [
            "draft",
            "verified",
            "blocked",
            "stale"
          ],
          "title": "State",
          "type": "string"
        },
        "source_run_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Run Id"
        },
        "source_artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Artifact Id"
        }
      },
      "required": [
        "assertion_id",
        "assertion_type",
        "state"
      ],
      "title": "AssertionCreatedPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "format": "uuid",
      "title": "Event Id",
      "type": "string"
    },
    "event_name": {
      "const": "assertion.created",
      "default": "assertion.created",
      "title": "Event Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "produced_by": {
      "minLength": 1,
      "title": "Produced By",
      "type": "string"
    },
    "trace_id": {
      "minLength": 1,
      "title": "Trace Id",
      "type": "string"
    },
    "request_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Request Id"
    },
    "tenant_id": {
      "format": "uuid",
      "title": "Tenant Id",
      "type": "string"
    },
    "project_id": {
      "format": "uuid",
      "title": "Project Id",
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 1,
      "title": "Idempotency Key",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/AssertionCreatedPayload"
    }
  },
  "required": [
    "event_id",
    "produced_by",
    "trace_id",
    "tenant_id",
    "project_id",
    "idempotency_key",
    "occurred_at",
    "payload"
  ],
  "title": "AssertionCreatedEvent",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}

{
  "$defs": {
    "ReviewCompletedPayload": {
      "additionalProperties": false,
      "properties": {
        "review_id": {
          "format": "uuid",
          "title": "Review Id",
          "type": "string"
        },
        "review_type": {
          "enum": [
            "evidence",
            "analysis",
            "manuscript",
            "export"
          ],
          "title": "Review Type",
          "type": "string"
        },
        "target_kind": {
          "minLength": 1,
          "title": "Target Kind",
          "type": "string"
        },
        "target_id": {
          "format": "uuid",
          "title": "Target Id",
          "type": "string"
        },
        "state": {
          "enum": [
            "pending",
            "approved",
            "rejected",
            "changes_requested"
          ],
          "title": "State",
          "type": "string"
        },
        "reviewer_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewer Id"
        },
        "decided_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decided At"
        }
      },
      "required": [
        "review_id",
        "review_type",
        "target_kind",
        "target_id",
        "state"
      ],
      "title": "ReviewCompletedPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "format": "uuid",
      "title": "Event Id",
      "type": "string"
    },
    "event_name": {
      "const": "review.completed",
      "default": "review.completed",
      "title": "Event Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "produced_by": {
      "minLength": 1,
      "title": "Produced By",
      "type": "string"
    },
    "trace_id": {
      "minLength": 1,
      "title": "Trace Id",
      "type": "string"
    },
    "request_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Request Id"
    },
    "tenant_id": {
      "format": "uuid",
      "title": "Tenant Id",
      "type": "string"
    },
    "project_id": {
      "format": "uuid",
      "title": "Project Id",
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 1,
      "title": "Idempotency Key",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/ReviewCompletedPayload"
    }
  },
  "required": [
    "event_id",
    "produced_by",
    "trace_id",
    "tenant_id",
    "project_id",
    "idempotency_key",
    "occurred_at",
    "payload"
  ],
  "title": "ReviewCompletedEvent",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}

{
  "$defs": {
    "ArtifactCreatedPayload": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "run_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "artifact_type": {
          "enum": [
            "dataset_snapshot",
            "result_json",
            "table",
            "figure",
            "log",
            "manifest",
            "docx",
            "pdf",
            "zip",
            "evidence_attachment"
          ],
          "title": "Artifact Type",
          "type": "string"
        },
        "storage_uri": {
          "minLength": 1,
          "title": "Storage Uri",
          "type": "string"
        },
        "sha256": {
          "maxLength": 64,
          "minLength": 64,
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "artifact_type",
        "storage_uri",
        "sha256"
      ],
      "title": "ArtifactCreatedPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "format": "uuid",
      "title": "Event Id",
      "type": "string"
    },
    "event_name": {
      "const": "artifact.created",
      "default": "artifact.created",
      "title": "Event Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "produced_by": {
      "minLength": 1,
      "title": "Produced By",
      "type": "string"
    },
    "trace_id": {
      "minLength": 1,
      "title": "Trace Id",
      "type": "string"
    },
    "request_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Request Id"
    },
    "tenant_id": {
      "format": "uuid",
      "title": "Tenant Id",
      "type": "string"
    },
    "project_id": {
      "format": "uuid",
      "title": "Project Id",
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 1,
      "title": "Idempotency Key",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/ArtifactCreatedPayload"
    }
  },
  "required": [
    "event_id",
    "produced_by",
    "trace_id",
    "tenant_id",
    "project_id",
    "idempotency_key",
    "occurred_at",
    "payload"
  ],
  "title": "ArtifactCreatedEvent",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}

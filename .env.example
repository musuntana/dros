APT_MIRROR_HOST=mirrors.tuna.tsinghua.edu.cn
PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
NPM_REGISTRY=https://mirrors.tencent.com/npm/

POSTGRES_DB=dros
POSTGRES_USER=dros
POSTGRES_PASSWORD=dros
DROS_POSTGRES_SCHEMA=dr_os_dev

# Optional frontend gateway override for future split-gateway deployments.
GATEWAY_BASE_URL=
NEXT_PUBLIC_GATEWAY_BASE_URL=

DROS_AUTH_MODE=dev_headers
DROS_AUTH_JWT_SECRET=
DROS_AUTH_OIDC_DISCOVERY_URL=
DROS_AUTH_JWKS_URL=
DROS_AUTH_INTROSPECTION_URL=
DROS_AUTH_INTROSPECTION_CLIENT_ID=
DROS_AUTH_INTROSPECTION_CLIENT_SECRET=
DROS_AUTH_INTROSPECTION_TOKEN_TYPE_HINT=access_token
DROS_AUTH_JWT_ALGORITHMS=HS256
DROS_AUTH_OIDC_CACHE_TTL_SECONDS=300
DROS_AUTH_JWKS_CACHE_TTL_SECONDS=300
DROS_AUTH_JWKS_TIMEOUT_SECONDS=5
DROS_AUTH_INTROSPECTION_TIMEOUT_SECONDS=5
DROS_AUTH_JWT_ISSUER=https://dev-idp.dros.local
DROS_AUTH_JWT_AUDIENCE=dros-control-plane
DROS_AUTH_PRINCIPAL_CLAIM=principal_id
DROS_AUTH_TENANT_CLAIM=tenant_id
DROS_AUTH_PROJECT_ROLE_CLAIM=project_role
DROS_AUTH_SCOPES_CLAIM=scope
DROS_AUTH_JTI_CLAIM=jti
DROS_AUTH_REQUIRE_JTI=false
DROS_AUTH_REVOKED_JTI_LIST=

# Optional external evidence switch for local testing.
DROS_NCBI_ENABLED=false
